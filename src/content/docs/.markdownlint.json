{
    "default": true,
    "MD013": false, // 关闭行字数限制
    "MD033": false, // 允许使用内联 HTML
    "MD041": false, // 不强制第一行是 H1
    "MD025": false, // 允许存在多个一级标题（如果你习惯的话）
    "MD040": false, // 允许围栏代码块不指定语言
    "MD045": false, // 允许图片没有替代文本（alt text）
    "MD036": false, // 允许使用粗体或斜体作为标题
    // "MD056": false, // 允许表格各行的列数不一致
    "MD060": false, // 允许表格各列的宽度/对齐样式不一致
    "MD024": false, // 允许存在多个内容相同的标题
    "MD028": false, // 允许引用块内存在空行 ，因为存在 多个callout
    "MD007": {
        "indent": 2
    } // 设置列表缩进为 4 个空格，匹配 Obsidian 的缩进习惯
}